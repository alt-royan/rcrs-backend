aws --endpoint-url=http://localhost:4566 s3api create-bucket --bucket images --region eu-west-1 --create-bucket-configuration LocationConstraint=eu-west-1
aws --endpoint-url=http://localhost:4566 s3api create-bucket --bucket rcrs-upload --region eu-west-1 --create-bucket-configuration LocationConstraint=eu-west-1
aws --endpoint-url=http://localhost:4566 sqs create-queue --queue-name rcrs-upload-queue
aws --endpoint-url=http://localhost:4566 sqs get-queue-attributes --queue-url http://sqs.eu-west-1.localhost.localstack.cloud:4566/000000000000/rcrs-upload-queue --attribute-names QueueArn
aws --endpoint-url=http://localhost:4566 sqs set-queue-attributes --queue-url http://sqs.eu-west-1.localhost.localstack.cloud:4566/000000000000/rcrs-upload-queue --attributes Policy=file://queue-policy.json
aws --endpoint-url=http://localhost:4566 s3api put-bucket-notification-configuration --bucket rcrs-upload --notification-configuration file://notification.json
